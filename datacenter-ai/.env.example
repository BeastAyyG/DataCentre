# Data Center AI - Environment Variables
# Copy this file to .env and fill in values
# Generate a real secret with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── App ──────────────────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
APP_DEBUG=true             # Must be false in production — enables verbose stack traces
# NOTE: Pydantic-Settings maps DEBUG (not APP_DEBUG) to the debug field

# ── Database ─────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./datacenter.db

# ── ML ────────────────────────────────────────────────────────────────────────────
MODEL_ARTIFACTS_PATH=ml/artifacts
MODEL_REGISTRY_PATH=ml/model_registry.json
RISK_THRESHOLD_WARNING=35   # Risk score below this → healthy (green)
RISK_THRESHOLD_CRITICAL=65 # Risk score above this → critical (red)

# ── Simulator ────────────────────────────────────────────────────────────────────
# SIMULATOR_SPEED=1.0   # 1.0 = real-time, 10.0 = 10x fast-forward for demos
# SIMULATOR_INTERVAL_SEC=2.0  # Seconds between simulated sensor readings

# ── ML Pipeline ─────────────────────────────────────────────────────────────────
# ML_PIPELINE_INTERVAL_SEC=30     # How often (seconds) the ML inference pipeline runs
# DRIFT_CHECK_INTERVAL_SEC=3600   # How often (seconds) model drift is checked
# KPI_SNAPSHOT_INTERVAL_SEC=300  # How often (seconds) KPI snapshots are computed

# ── Energy Cost ─────────────────────────────────────────────────────────────────
ENERGY_COST_PER_KWH=0.10  # USD per kWh — used for What-If annual savings calculation

# ── Server ──────────────────────────────────────────────────────────────────────
BACKEND_HOST=127.0.0.1    # Use 127.0.0.1 for local dev; use 0.0.0.0 only inside Docker
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
