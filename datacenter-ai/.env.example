# Data Center AI - Environment Variables
# Copy this file to .env and fill in values
# Generate a real secret with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# App
APP_ENV=development
APP_DEBUG=true

# Database - PostgreSQL (industry standard)
# For local dev without Docker: postgresql://dcadmin:dcpassword@localhost:5432/datacenter_ai
# For Docker: postgresql://dcadmin:dcpassword@postgres:5432/datacenter_ai
DATABASE_URL=postgresql://dcadmin:dcpassword@localhost:5432/datacenter_ai

# ML
MODEL_ARTIFACTS_PATH=ml/artifacts
MODEL_REGISTRY_PATH=ml/model_registry.json
RISK_THRESHOLD_WARNING=35
RISK_THRESHOLD_CRITICAL=65

# Simulator
SIMULATOR_SPEED=1.0
SIMULATOR_INTERVAL_SEC=2.0

# ML Pipeline
ML_PIPELINE_INTERVAL_SEC=30
DRIFT_CHECK_INTERVAL_SEC=3600
KPI_SNAPSHOT_INTERVAL_SEC=300

# Energy Cost
ENERGY_COST_PER_KWH=0.10

# Server
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000

# Authentication
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Observability
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_METRICS=true

# Multi-datacenter
DEFAULT_DATACENTER_ID=dc-primary
