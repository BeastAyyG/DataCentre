# Data Center AI — ML Pipeline Detail

```mermaid
flowchart TD
    %% Input
    subgraph INPUT ["INPUT — Raw Sensor Data"]
        R1["sensor_readings table\n(last 100 readings per device)"]
    end

    %% IsolationForest
    subgraph IF ["IsolationForest (Weight: 50%)"]
        IF1["Feature Vector\n[inlet_temp_c,\n outlet_temp_c,\n power_kw,\n airflow_cfm,\n humidity_pct,\n cpu_util_pct]"]
        IF2["StandardScaler\n(normalise to mean=0, std=1)"]
        IF3["IsolationForest.decision_function()\n→ raw anomaly score"]
        IF4["Sigmoid normalisation\n1 / (1 + exp(-score × 10))\n→ anomaly_confidence ∈ [0,1]"]
    end

    %% Prophet Forecaster
    subgraph PROPHET ["Prophet Forecaster (Weight: 35%)"]
        P1["Historical time-series\n[ds, y, cooling_setpoint_c,\n hour_of_day, day_of_week]"]
        P2["Prophet.predict()\n60-minute horizon, 5-min intervals"]
        P3["Forecast: yhat, yhat_upper, yhat_lower"]
        P4["Forecast Deviation =\nmax(0, observed - upper_bound)\n/ band_width"]
    end

    %% Alert Frequency
    subgraph FREQ ["Alert Frequency Bonus (Weight: 15%)"]
        F1["Count alerts per device\n(last 24 hours)"]
        F2["alert_freq =\nmin(count / 10, 1.0)"]
    end

    %% Ensemble
    subgraph ENSEMBLE ["RiskScorer Ensemble"]
        E1["raw =\n0.50 × IF_conf\n+ 0.35 × fc_dev\n+ 0.15 × alert_freq"]
        E2["risk_score =\nclip(raw × 100, 0, 100)"]
        E3["Label:\n< 35 → Healthy\n35-65 → At Risk\n> 65 → Critical"]
    end

    %% Output
    subgraph OUTPUT ["OUTPUT — Actions"]
        O1["Risk Score + Label\n→ Device.current_risk_score"]
        O2["If at_risk or critical:\n→ AnomalyAlert created"]
        O3["recommended_action:\nfrom action template by\naffected_metric"]
    end

    %% Connections
    R1 --> IF1
    R1 --> P1
    R1 --> F1
    IF1 --> IF2 --> IF3 --> IF4 --> E1
    P1 --> P2 --> P3 --> P4 --> E1
    F1 --> F2 --> E1
    E1 --> E2 --> E3
    E3 --> O1
    O1 --> O2 --> O3

    %% Styling
    style IF fill:#1e3a8a,color:#fff,stroke:#3b82f6
    style PROPHET fill:#14532d,color:#fff,stroke:#22c55e
    style FREQ fill:#78350f,color:#fff,stroke:#f59e0b
    style ENSEMBLE fill:#4c1d95,color:#fff,stroke:#a855f7
    style OUTPUT fill:#450a0a,color:#fff,stroke:#ef4444
    style INPUT fill:#1e293b,color:#fff,stroke:#64748b
```
